# Protects /dashboard and /api/users. There are no default credentials.
BASIC_AUTH_USER="your_username"
BASIC_AUTH_PASS="your_password"

# Prisma Accelerate connection URL
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=your_api_key"

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your_turnstile_site_key"
TURNSTILE_SECRET_KEY="your_turnstile_secret_key"

# Optional canonical origin used by the generated sitemap
SITE_URL="https://www.crystalharphealing.com"
